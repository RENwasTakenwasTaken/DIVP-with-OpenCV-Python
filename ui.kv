
<ApplicationScreen>:
    orientation: 'vertical'
    canvas.before:
        Color:
            rgba: 0, 0, 0, 1
        Rectangle:
            size: self.size
            pos: self.pos

    BoxLayout:  # Top Bar.
        size_hint_y: 0.1
        Button:
            text: "Choose Image"
            on_press: root.open_file_dialog()
            size_hint: None, None
            width: 200

        Label:
            id: title_bar_text
            text: "No images added"

    BoxLayout: # Tool Bar.
        size_hint_y: 0.1
        Button:
            text: "Invert"
            on_press: root.apply_image_negation()

        Button:
            text: "Apply Log"
            on_press: root.apply_image_log_transform()

        Button:
            text: "Image Data"
            on_press: root.print_image_data()

    BoxLayout:  # Middle Section.
        ImageCanvas:
            id: image_canvas
            
        BoxLayout:     # Layer manager.
            size_hint_x: 0.1
            orientation: 'vertical'
